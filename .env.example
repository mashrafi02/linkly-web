# Base URL of the linkly-api backend this app talks to
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public URL of this frontend (used for canonical/OpenGraph metadata, sitemap, robots.txt)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe publishable key (safe to expose client-side) — used to mount Stripe Elements on /billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
